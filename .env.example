# ============================================
# EduERP Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# Database
DATABASE_URL=postgresql://eduerp:eduerp_secret@localhost:5432/eduerp
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=eduerp
DATABASE_PASSWORD=eduerp_secret
DATABASE_NAME=eduerp

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# API
API_PORT=3001
API_PREFIX=api/v1

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_NAME=EduERP
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Super Admin Seed
SUPER_ADMIN_EMAIL=admin@eduerp.com
SUPER_ADMIN_PASSWORD=Admin@123456
SUPER_ADMIN_NAME=System Administrator

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Node Environment
NODE_ENV=development
